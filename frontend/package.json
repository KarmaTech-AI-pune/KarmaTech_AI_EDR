{
  "name": "edrprojectmanagement-frontend",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tenant1": "vite --config vite.config.tenant1.ts",
    "dev:tenant2": "vite --config vite.config.tenant2.ts",
    "build": "tsc -b && vite build",
    "build:tenant1": "tsc -b && vite build --config vite.config.tenant1.ts",
    "build:tenant2": "tsc -b && vite build --config vite.config.tenant2.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.0.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/lab": "^6.0.1-beta.36",
    "@mui/material": "^6.5.0",
    "@mui/x-date-pickers": "^7.22.2",
    "axios": "^1.7.7",
    "date-fns": "^2.30.0",
    "formik": "^2.4.6",
    "jwt-decode": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.66.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^2.15.1",
    "uuid": "^11.0.3",
    "wx-react-gantt": "^1.3.1",
    "xlsx": "^0.18.5",
    "yup": "^1.6.1",
    "zod": "^3.25.41"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.11.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.9.0",
    "jsdom": "^26.0.0",
    "msw": "^2.10.5",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.7.0",
    "vite": "^5.4.8",
    "vitest": "^3.0.9"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.58.0",
    "@swc/core-linux-x64-gnu": "^1.15.11"
  }
}
