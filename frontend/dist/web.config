<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <rule name="Tenant Routing" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{HTTP_HOST}" pattern="^([^.]+)\.karmatech-ai\.com$" />
                    </conditions>
                    <action type="Rewrite" url="{R:1}" />
                    <serverVariables>
                        <set name="HTTP_X_TENANT_CONTEXT" value="{C:1}" />
                    </serverVariables>
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
