# API Configuration
VITE_API_BASE_URL=http://api.karmatech-ai.com
VITE_STATIC_IP=
VITE_USE_STATIC_IP=false

# Tenant Configuration
VITE_TENANT_PROTOCOL=http
VITE_TENANT_DOMAIN=karmatech-ai.com
VITE_TENANT_PORT=80

# Additional Settings
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_LOGGING=false

# Build Configuration
VITE_ENV=production

