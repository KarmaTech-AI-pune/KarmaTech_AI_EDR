{
  "enabled": true,
  "name": "Pre-Release Testing",
  "description": "Runs integration and regression test suites before release deployment",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run pre-release testing:\n1. Execute Run-Integration-Tests.ps1 (backend tests)\n2. Execute Run-Regression-Tests.ps1 (full stack tests)\n3. Generate test report\n\nProceed with testing now."
  },
  "workspaceFolderName": "KarmaTech_AI_EDR",
  "shortName": "pre-release-testing"
}